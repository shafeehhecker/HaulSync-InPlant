# ─── Database ────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://postgres:password@localhost:5432/haulsync_inplant?schema=public"

# ─── Auth ────────────────────────────────────────────────────────────────────
JWT_SECRET="change-me-to-a-long-random-string-in-production"

# ─── Server ──────────────────────────────────────────────────────────────────
PORT=5001
NODE_ENV=development
FRONTEND_URL=http://localhost:3001

# ─── Detention Engine ─────────────────────────────────────────────────────────
FREE_TIME_MINUTES=180
DETENTION_RATE_PER_HOUR=750
DETENTION_ALERT_AT_MINUTES=60
DETENTION_ESCALATE_AT_MINUTES=30

# ─── Email Alerts (optional) ──────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=alerts@yourcompany.com
SMTP_PASS=your-app-password
ALERT_FROM_EMAIL=alerts@yourcompany.com

# ─── File Uploads ─────────────────────────────────────────────────────────────
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=10
